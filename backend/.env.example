# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/notes_db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
DEBUG=True
APP_NAME=Notes Management System
APP_VERSION=1.0.0

# CORS Configuration - Set the frontend URL for production
# Development: Will use default localhost URLs
# Production: Set to your Vercel frontend URL
FRONTEND_URL=https://advance-notes-management.vercel.app

